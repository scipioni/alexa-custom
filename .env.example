LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_ROOM=your-room-name
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Optional: override the audio devices used for input and output.
# Accepts a sounddevice index (integer) or a substring of the device name.
# Defaults to the PipeWire default sink/source when unset.
#INPUT_DEVICE=pipewire
#OUTPUT_DEVICE=pipewire

# Optional: microphone WebRTC processing (all default to 1/enabled).
# Set to 0 to disable if your speakerphone already handles echo/noise.
#MIC_AGC=1
#MIC_AEC=1
#MIC_NOISE_SUPPRESSION=1
#MIC_HIGH_PASS_FILTER=1

# Telegram Bot API credentials (required for telegram action type in actions.yaml).
# Create a bot via @BotFather on Telegram, then get the chat ID from @userinfobot.
#TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHH-your-token-here
#TELEGRAM_CHAT_ID=123456789
