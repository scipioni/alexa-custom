# Wake words (Italian phonetically-distinct words work best).
# Any word in this list triggers the command listening window.
wake_words:
  - "galileo"
  - "aiuto"

# How long to listen for a command after the wake word is detected (seconds).
# Only used in two-stage mode.
command_timeout: 3.0

# Recognition mode:
#   two-stage    — wake word detected first (low CPU), then a timed command window opens.
#                  Requires a short pause between wake word and command (the beep is the prompt).
#   single-stage — full transcription always; say wake word + command in one phrase
#                  ("galileo chiama"). Higher CPU, no pause needed.
recognition_mode: two-stage

# Minimum Vosk confidence (0.0–1.0) required to accept a wake word in two-stage mode.
# Higher values reduce false positives but may miss quieter/faster pronunciations.
# Lower values increase sensitivity but risk triggering on unrelated speech.
# Default 0.75 works well for the full model; try 0.60–0.70 with the small model.
wake_confidence: 0.75

# Triggers: map spoken phrases to action sequences.
# The phrase is matched against the Vosk transcription using fuzzy matching
# (difflib, threshold 0.70) — so minor variations in Italian inflection are OK.
triggers:
  # Test trigger: say the wake word then "test" — check logs for confirmation
  - phrase: "test"
    actions:
      - type: log
        message: "wake word and command recognition working"

  - phrase: "chiama"
    actions:
      - type: livekit_join
        # Optional: room name override. Defaults to LIVEKIT_ROOM env var.
        # room: "sala-riunioni"

  - phrase: "manda messaggio"
    actions:
      - type: telegram
        # Optional: target chat. Defaults to TELEGRAM_CHAT_ID env var.
        # chat_id: "123456789"
        text: "Qualcuno ti chiama dal salotto"

  # Example: trigger both actions in sequence
  - phrase: "emergenza"
    actions:
      - type: telegram
        text: "ATTENZIONE: richiesta di aiuto dal salotto"
      - type: livekit_join
