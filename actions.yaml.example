# Example actions.yaml configuration for alexa-custom

# Wake words that trigger the command window (single words recommended)
wake_words:
  - "alexa"
  - "computer"

# Recognition mode: 
# "two-stage" (default): wake word -> beep -> command
# "single-stage": "alexa do something" (wake word + command in one phrase)
recognition_mode: "two-stage"

# Confidence threshold for wake word detection (0.0 to 1.0)
wake_confidence: 0.75

# How long to wait for a command after the wake word (seconds)
command_timeout: 4.0

# Actions to run when the application starts
on_startup:
  - type: tone
    name: startup  # The ascending C-E-G chime
  - type: say
    text: "Sistema pronto"
    lang: "it-IT"

# Triggers map voice transcripts (fuzzy matched) to a list of actions.
# Fuzzy matching threshold is 0.70.
triggers:
  - phrase: "notifica"
    actions:
      - type: log
        message: "Sending telegram notification..."
      - type: telegram
        text: "User requested attention from NewPie!"
      - type: tone
        name: success

  - phrase: "connettiti"
    actions:
      - type: livekit_join
      - type: tone
        name: info

  - phrase: "prova i suoni"
    actions:
      - type: tone
        name: success
      - type: tone
        name: error
      - type: tone
        name: info
      - type: tone
        name: warning

  - phrase: "chiama scipio"
    actions:
      - type: telegram
        text: "Richiesta chiamata LiveKit: <room>"
      - type: livekit_join
      - type: say
        text: "Sto chiamando Scipio su Telegram e mi connetto alla stanza."

  - phrase: "chiudi"
    actions:
      - type: log
        message: "Exit requested via voice"
      - type: say
        text: "Spegnimento in corso"
      # Future: add a shutdown action type if needed
